{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Setup Django Backend",
            "type": "shell",
            "command": "python3 -m venv octofit-tracker/backend/venv && source octofit-tracker/backend/venv/bin/activate && pip install -r octofit-tracker/backend/requirements.txt",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Run Django Migrations",
            "type": "shell",
            "command": "source octofit-tracker/backend/venv/bin/activate && python octofit-tracker/backend/manage.py migrate",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Populate Database",
            "type": "shell",
            "command": "source octofit-tracker/backend/venv/bin/activate && python octofit-tracker/backend/manage.py populate_db",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Install Frontend Dependencies",
            "type": "shell",
            "command": "npm install --prefix octofit-tracker/frontend",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        },
        {
            "label": "Start React Frontend",
            "type": "shell",
            "command": "npm start --prefix octofit-tracker/frontend",
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "BROWSER": "none"
                }
            },
            "group": "build",
            "isBackground": true,
            "presentation": {
                "reveal": "always",
                "panel": "new"
            }
        }
    ]
}
