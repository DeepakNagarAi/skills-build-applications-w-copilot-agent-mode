{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Django Backend",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/octofit-tracker/backend/manage.py",
            "args": [
                "runserver",
                "0.0.0.0:8000"
            ],
            "django": true,
            "cwd": "${workspaceFolder}/octofit-tracker/backend",
            "env": {
                "DJANGO_SETTINGS_MODULE": "octofit_tracker.settings",
                "PYTHONPATH": "${workspaceFolder}/octofit-tracker/backend"
            },
            "python": "${workspaceFolder}/octofit-tracker/backend/venv/bin/python3"
        },
        {
            "name": "React Frontend",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["start"],
            "cwd": "${workspaceFolder}/octofit-tracker/frontend",
            "env": {
                "BROWSER": "none"
            },
            "serverReadyAction": {
                "pattern": "Local:.*:(\\d+)",
                "uriFormat": "http://localhost:%s",
                "action": "openExternally"
            }
        }
    ]
}
